# Porta do app runtime (build de producao servido por nginx)
ACCESS_SUITE_PORT=8088

# Porta do app em desenvolvimento com Vite
ACCESS_SUITE_DEV_PORT=8080

# URL da API central acessivel pelo navegador do celular.
# Exemplo:
# VITE_API_URL=http://192.168.0.15:3000
VITE_API_URL=http://192.168.18.147:3000

# Modo padrao do bundle mobile no runtime Docker
VITE_APP_MODE=backend

# Habilita polling de arquivos quando necessario em Docker/WSL
CHOKIDAR_USEPOLLING=true
