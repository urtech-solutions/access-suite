# Porta do app runtime (build de producao servido por nginx)
ACCESS_SUITE_PORT=8088

# Porta do app em desenvolvimento com Vite
ACCESS_SUITE_DEV_PORT=8080

# Modo inicial do app no build Docker.
# Use `backend` para refletir o ambiente real.
# Use `preview` apenas se quiser forcar o modo demonstracao no container.
VITE_APP_MODE=backend

# Base path onde o app sera publicado no proxy externo.
VITE_APP_BASE_PATH=/access-os/

# URL da API central acessivel pelo navegador.
# Use /api quando acessar pelo nginx central:
#   https://192.168.1.111/access-os/
VITE_API_URL=/api

# Habilita polling de arquivos quando necessario em Docker/WSL
CHOKIDAR_USEPOLLING=true
